# MongoDB Connection
# Get your connection string from MongoDB Atlas
MONGODB_URI="mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=YOUR_APP"

# JWT Configuration
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET="YOUR_SECURE_JWT_SECRET_HERE_MINIMUM_256_BITS"
JWT_EXPIRES_IN="8h"

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:8080"

# Optional: Custom ping message
PING_MESSAGE="ping"
